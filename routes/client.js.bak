const express = require('express');
const router = express.Router();
const multer = require('multer');
const path = require('path');
const fs = require('fs');
const { clientsDB, docsDB, checklistDB, feedbackDB } = require('../database/db');
const { sendMessage, MESSAGES } = require('../services/whatsapp');
const { uploadFile, createClientFolder } = require('../services/drive');

const APP_URL = process.env.APP_URL || 'http://localhost:3000';

// Multer config
const storage = multer.diskStorage({
  destination: (req, file, cb) => {
    const dir = path.join(__dirname, '..', 'uploads', 'temp');
    fs.mkdirSync(dir, { recursive: true });
    cb(null, dir);
  },
  filename: (req, file, cb) => {
    const unique = Date.now() + '-' + Math.round(Math.random() * 1E9);
    cb(null, unique + path.extname(file.originalname));
  }
});

const upload = multer({
  storage,
  limits: { fileSize: 20 * 1024 * 1024 }, // 20MB
  fileFilter: (req, file, cb) => {
    if (file.mimetype === 'application/pdf') cb(null, true);
    else cb(new Error('רק קבצי PDF מותרים'));
  }
});

// GET /api/client/status - check client status by phone
router.get('/status', (req, res) => {
  const phone = req.query.phone;
  if (!phone) return res.json({ exists: false });

  // Check if blocked
  if (clientsDB.isBlocked(phone)) {
    const client = clientsDB.findByPhone(phone);
    const blockUntil = new Date(client.block_until);
    const daysLeft = Math.ceil((blockUntil - new Date()) / (1000 * 60 * 60 * 24));
    return res.json({
      exists: true,
      blocked: true,
      block_reason: client.block_reason,
      block_until: client.block_until,
      days_left: daysLeft
    });
  }

  const client = clientsDB.findByPhone(phone);
  if (!client) return res.json({ exists: false });

  return res.json({
    exists: true,
    blocked: false,
    current_step: client.current_step,
    status: client.status,
    passport_status: client.passport_status,
    payment_status: client.payment_status,
    name: client.first_name
  });
});

// POST /api/client/register - Step 1: register client with personal details + passport upload
router.post('/register', upload.single('passport_file'), async (req, res) => {
  try {
    const {
      phone, first_name, last_name, email, id_number, birth_date,
      passport_number, passport_name_en, passport_surname_en, passport_valid, preferred_bank
    } = req.body;

    if (!phone || !first_name || !last_name) {
      return res.status(400).json({ error: 'שדות חובה חסרים' });
    }

    // Check if blocked
    if (clientsDB.isBlocked(phone)) {
      return res.status(403).json({ error: 'מספר זה חסום' });
    }

    // Check if already registered
    let client = clientsDB.findByPhone(phone);
    if (client) {
      return res.status(409).json({ error: 'מספר טלפון זה כבר רשום במערכת', current_step: client.current_step });
    }

    // Create client
    const result = clientsDB.create({
      phone, first_name, last_name, email, id_number, birth_date,
      passport_number, passport_name_en, passport_surname_en,
      passport_valid: passport_valid === 'true' ? 1 : 0,
      preferred_bank
    });

    const newClient = clientsDB.findById(result.lastInsertRowid);

    // Upload passport to Drive if file provided
    if (req.file) {
      const folderResult = await createClientFolder(
        `${first_name} ${last_name}`,
        phone,
        process.env.DRIVE_FOLDER_PASSPORT
      );

      if (folderResult.success) {
        const uploadResult = await uploadFile(
          req.file.path,
          `passport_${first_name}_${last_name}.pdf`,
          'application/pdf',
          folderResult.folderId
        );

        if (uploadResult.success) {
          docsDB.add({
            client_id: newClient.id,
            doc_type: 'passport',
            original_name: req.file.originalname,
            drive_file_id: uploadResult.fileId,
            drive_url: uploadResult.webViewLink
          });
        }

        // Clean up temp file
        fs.unlinkSync(req.file.path);
      }
    }

    // Update step to waiting
    clientsDB.update(newClient.id, { current_step: 2, passport_status: 'reviewing' });

    // Send WhatsApp notification
    await sendMessage(
      phone,
      MESSAGES.STEP1_RECEIVED(first_name),
      newClient.id
    );

    return res.json({
      success: true,
      message: 'הפרטים התקבלו בהצלחה',
      client_id: newClient.id,
      current_step: 2
    });
  } catch (error) {
    console.error('Register error:', error);
    res.status(500).json({ error: 'שגיאת שרת' });
  }
});

// POST /api/client/checklist - Step 7: submit checklist
router.post('/checklist', (req, res) => {
  const { phone, poa_ready, apostille_ready, payslips_ready, passport_ready, bank_confirm_ready, bank_statements_ready, address_proof_ready } = req.body;

  const client = clientsDB.findByPhone(phone);
  if (!client) return res.status(404).json({ error: 'לקוח לא נמצא' });

  checklistDB.upsert(client.id, {
    poa_ready: poa_ready ? 1 : 0,
    apostille_ready: apostille_ready ? 1 : 0,
    payslips_ready: payslips_ready ? 1 : 0,
    passport_ready: passport_ready ? 1 : 0,
    bank_confirm_ready: bank_confirm_ready ? 1 : 0,
    bank_statements_ready: bank_statements_ready ? 1 : 0,
    address_proof_ready: address_proof_ready ? 1 : 0
  });

  clientsDB.updateStep(client.id, 8);

  // Send WhatsApp
  sendMessage(phone, MESSAGES.CHECKLIST_DONE(client.first_name, `${APP_URL}/client?phone=${encodeURIComponent(phone)}`), client.id);

  res.json({ success: true, current_step: 8 });
});

// POST /api/client/upload-docs - Step 8: upload all documents
const docFields = [
  { name: 'poa_doc', maxCount: 1 },
  { name: 'apostille_doc', maxCount: 1 },
  { name: 'payslips_doc', maxCount: 1 },
  { name: 'passport_doc', maxCount: 1 },
  { name: 'bank_confirm_doc', maxCount: 1 },
  { name: 'bank_statements_doc', maxCount: 1 },
  { name: 'address_proof_doc', maxCount: 1 }
];

router.post('/upload-docs', upload.fields(docFields), async (req, res) => {
  try {
    const { phone } = req.body;
    const client = clientsDB.findByPhone(phone);
    if (!client) return res.status(404).json({ error: 'לקוח לא נמצא' });

    const docTypeMap = {
      poa_doc: 'ייפוי_כח',
      apostille_doc: 'אפוסטיל',
      payslips_doc: 'תלושי_שכר',
      passport_doc: 'דרכון',
      bank_confirm_doc: 'אישור_בנק',
      bank_statements_doc: 'תדפיסי_בנק',
      address_proof_doc: 'הוכחת_כתובת'
    };

    const folderResult = await createClientFolder(
      `${client.first_name} ${client.last_name}`,
      phone,
      process.env.DRIVE_FOLDER_DOCUMENTS
    );

    for (const [fieldName, docType] of Object.entries(docTypeMap)) {
      const files = req.files[fieldName];
      if (files && files[0]) {
        const file = files[0];
        const fileName = `${docType}_${client.first_name}_${client.last_name}.pdf`;

        let driveResult = { success: false };
        if (folderResult.success) {
          driveResult = await uploadFile(file.path, fileName, 'application/pdf', folderResult.folderId);
        }

        docsDB.add({
          client_id: client.id,
          doc_type: docType,
          original_name: file.originalname,
          drive_file_id: driveResult.fileId || null,
          drive_url: driveResult.webViewLink || null
        });

        // Clean up temp file
        if (fs.existsSync(file.path)) fs.unlinkSync(file.path);
      }
    }

    clientsDB.updateStep(client.id, 9);

    // Send WhatsApp
    const lawyerAddress = 'Batumi, Georgia - הכתובת המלאה תימסר בנפרד';
    sendMessage(phone, MESSAGES.DOCS_UPLOADED(client.first_name, lawyerAddress), client.id);

    res.json({ success: true, current_step: 9 });
  } catch (error) {
    console.error('Upload docs error:', error);
    res.status(500).json({ error: 'שגיאת שרת' });
  }
});

// POST /api/client/tracking - Step 9: submit tracking number
router.post('/tracking', (req, res) => {
  const { phone, tracking_number, shipping_company } = req.body;

  const client = clientsDB.findByPhone(phone);
  if (!client) return res.status(404).json({ error: 'לקוח לא נמצא' });

  clientsDB.update(client.id, {
    tracking_number,
    shipping_company,
    current_step: 10
  });

  // Send WhatsApp
  sendMessage(phone, MESSAGES.TRACKING_RECEIVED(client.first_name), client.id);

  res.json({ success: true, current_step: 10 });
});

// POST /api/client/feedback - Final step: submit feedback
router.post('/feedback', (req, res) => {
  const { phone, account_opened, service_rating, response_rating, accessibility_rating, recommend_rating, comment } = req.body;

  const client = clientsDB.findByPhone(phone);
  if (!client) return res.status(404).json({ error: 'לקוח לא נמצא' });

  feedbackDB.add({
    client_id: client.id,
    account_opened: account_opened ? 1 : 0,
    service_rating: parseInt(service_rating),
    response_rating: parseInt(response_rating),
    accessibility_rating: parseInt(accessibility_rating),
    recommend_rating: parseInt(recommend_rating),
    comment
  });

  clientsDB.update(client.id, { current_step: 12, status: 'completed' });

  res.json({ success: true, message: 'תודה על המשוב!' });
});

module.exports = router;
